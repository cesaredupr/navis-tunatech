# ── Base de datos PostgreSQL/PostGIS ─────────────────────────────────────────
# Opción A: URL completa (recomendada para producción/Vercel)
# DATABASE_URL=postgresql://navis_admin:TU_PASSWORD_SEGURA@localhost:5433/navis_tunatech

# Opción B: Variables separadas (para desarrollo local)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=navis_tunatech
DB_USER=navis_admin
DB_PASSWORD=TU_PASSWORD_SEGURA_AQUI
DB_SSL=false

# ── Coordenadas por defecto (zona Pacífico guatemalteco) ──────────────────────
DEFAULT_LAT=14.0
DEFAULT_LON=-91.0

# ── Open-Meteo Marine API (gratuita, sin API key) ────────────────────────────
OPENMETEO_BASE_URL=https://marine-api.open-meteo.com/v1/marine

# ── Valhalla (opcional — solo si tienes el contenedor corriendo) ─────────────
# VALHALLA_URL=http://localhost:8002

# ── GeoServer (WMS local) ────────────────────────────────────────────────────
GEOSERVER_URL=http://localhost:8080/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=TU_PASSWORD_GEOSERVER_AQUI

# ── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=development
